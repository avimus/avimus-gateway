{
  "name": "avimus-gateway",
  "version": "1.0.0",
  "description": "WebSocket gateway between hospital ERP containers and the Avimus Patient Journey API",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch & node --watch dist/index.js",
    "start": "node dist/index.js",
    "test": "tsc && node --test \"dist-test/tests/**/*.test.js\""
  },
  "dependencies": {
    "axios": "^1.7.9",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.6.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.9",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
