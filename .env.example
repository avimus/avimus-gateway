# Copie este arquivo para ".env" e preencha com valores reais.
# NUNCA commite o arquivo ".env" (já está no .gitignore).

# Porta HTTP/WS do gateway
PORT=8080

# Segredo HMAC usado para validar (e no emissor, assinar) os tokens JWT
# apresentados pelos containers apx-health-socket no handshake.
GATEWAY_JWT_SECRET=troque-por-um-segredo-forte-e-aleatorio

# URL base da API Ávimus Patient Journey (Hono, Vercel)
AVIMUS_API_URL=https://api.avimus.example.com

# Segredo compartilhado: usado tanto nas chamadas de saída do gateway para a
# API Ávimus quanto para autenticar chamadas de entrada em /metrics e
# /admin/revoke (header x-internal-secret).
AVIMUS_INTERNAL_SECRET=troque-por-outro-segredo-forte-e-aleatorio

# Nível de log do pino: debug | info | warn | error
LOG_LEVEL=info

# Capacidade máxima da fila de mensagens em memória, por hospital
MAX_QUEUE_PER_TENANT=100
